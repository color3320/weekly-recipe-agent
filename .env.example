# Copy to `.env` and fill in values. NEVER commit `.env`.

# Model (pick one provider)
ANTHROPIC_API_KEY=
AGENT_MODEL=anthropic:claude-sonnet-4-6

# MongoDB (recipe ETL + agent tools)
MONGODB_URI=mongodb://localhost:27017/weekly_recipes
MONGODB_DB=weekly_recipes

# Atlas Automated Embedding: configure Voyage API keys in the Atlas UI
# (Search & Vector Search → Automated Embedding), not in this file.

# Legacy Postgres (hotel agent — replaced in later phases)
DATABASE_URL=postgresql://hotel_hackathon:PASSWORD@HOST/hotel_hackathon

# Production API auth (set on Render web service too)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Production mode (set on Render web service)
ENV=production

# LangGraph step budget per turn (default 40)
AGENT_RECURSION_LIMIT=40
