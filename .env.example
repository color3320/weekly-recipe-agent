# Copy to `.env` and fill in values. NEVER commit `.env`.

# Model (pick one provider)
ANTHROPIC_API_KEY=
AGENT_MODEL=anthropic:claude-sonnet-4-6

# MongoDB (recipe ETL + agent tools)
# atlas-local is a single-node replica set — directConnection=true is required.
MONGODB_URI=mongodb://localhost:27017/weekly_recipes?directConnection=true
MONGODB_DB=weekly_recipes

# Voyage AI — required for auto-embed on atlas-local preview (index-time + query-time).
# On hosted Atlas you can set this here or configure the key in the Atlas UI instead.
VOYAGE_API_KEY=

# Auto-embed index build can take 30+ min on 6.8k docs (Voyage rate limits on free tier).
# INDEX_READY_TIMEOUT_SEC=3600

# Legacy Postgres (hotel agent — replaced in later phases)
DATABASE_URL=postgresql://hotel_hackathon:PASSWORD@HOST/hotel_hackathon

# Production API auth (set on Render web service too)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Production mode (set on Render web service)
ENV=production

# LangGraph step budget per turn (default 40)
AGENT_RECURSION_LIMIT=40
